# =====================================================
# PopUp Studio ГўВЂВ” variГѓВЎveis de ambiente
# Copie para .env (local) e configure no painel da Vercel (prod).
# =====================================================

# ---- Nuvemshop Partner App ----
# Obtidos em https://partners.nuvemshop.com.br depois de criar o app.
NUVEMSHOP_CLIENT_ID=
NUVEMSHOP_CLIENT_SECRET=

# ---- Supabase ----
# Obtidos em https://supabase.com > seu projeto > Settings > API
# IMPORTANTE: use o SERVICE_ROLE key (nГѓВЈo o anon). NUNCA expor no frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- URL pГѓВєblica do app (Vercel) ----
APP_URL=https://popup-studio.vercel.app

# ---- Identidade do app (vai no header User-Agent das chamadas ГѓВ  Nuvemshop) ----
APP_NAME=PopUp Studio
APP_EMAIL=contato@popupstudio.app

# ---- Segredo de sessГѓВЈo (gere com: openssl rand -hex 32) ----
SESSION_SECRET=troque-isso-por-uma-string-aleatoria-de-64-chars
